      >
        <form
          class="usa-form maxw-none padding-bottom-6"
          data-testid="custom-date-form"
          id="custom-date-form"
        >
          <fieldset
            class="usa-fieldset"
            data-testid="fieldset"
          >
            <div
              class="usa-form-group margin-top-0 margin-bottom-3"
              data-testid="formGroup"
            >
              <label
                class="usa-label maxw-none margin-bottom-0 text-bold"
                data-testid="label"
                for="date-title"
              >
                Date title 
                <abbr
                  class="usa-hint usa-hint--required"
                  title="required"
                >
                  *
                </abbr>
              </label>
              <input
                class="usa-input"
                data-testid="date-title"
                id="date-title"
                name="title"
                type="text"
                value=""
              />
            </div>
            <div
              class="usa-form-group margin-top-0 margin-bottom-3"
              data-testid="formGroup"
            >
              <label
                class="usa-label maxw-none margin-bottom-0 text-bold"
                data-testid="label"
                for="date-description"
              >
                Date description
              </label>
              <textarea
                aria-labelledby="label-date-description hint-date-description"
                class="usa-textarea"
                data-testid="date-description"
                id="date-description"
                name="description"
              />
            </div>
            <div
              class="usa-form-group margin-top-0 margin-bottom-2"
              data-testid="formGroup"
            >
              <label
                class="usa-label text-bold maxw-none margin-bottom-0"
                data-testid="label"
                for="SINGLE"
              >
                Date type 
                <abbr
                  class="usa-hint usa-hint--required"
                  title="required"
                >
                  *
                </abbr>
              </label>
              <div
                class="usa-radio margin-right-1"
                data-testid="radio"
              >
                <input
                  class="usa-radio__input"
                  data-testid="SINGLE"
                  id="SINGLE"
                  name="dateType"
                  type="radio"
                  value="SINGLE"
                />
                <label
                  class="usa-radio__label"
                  for="SINGLE"
                >
                  Single date
                </label>
              </div>
              <div
                class="usa-radio margin-right-1"
                data-testid="radio"
              >
                <input
                  class="usa-radio__input"
                  data-testid="RANGE"
                  id="RANGE"
                  name="dateType"
                  type="radio"
                  value="RANGE"
                />
                <label
                  class="usa-radio__label"
                  for="RANGE"
                >
                  Date range
                </label>
              </div>
            </div>
          </fieldset>
          <button
            class="usa-button usa-button margin-top-4 margin-bottom-2"
