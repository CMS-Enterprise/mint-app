meta {
  name: Lock Task List Section
  type: graphql
  seq: 4
}

post {
  url: {{url}}
  body: graphql
  auth: apikey
}

auth:apikey {
  key: Authorization
  value: Local {"EUAID":"{{EUAID}}","jobCodes":{{jobCodes}},"favorLocalAuth":true}
  placement: header
}

body:graphql {
  mutation lockLockableSection ($modelPlanID: UUID!, $section: LockableSection!) {
      lockLockableSection (modelPlanID: $modelPlanID, section: $section)
  }
}

body:graphql:vars {
  {
    "modelPlanID": "",
    "section": ""
  }
}
