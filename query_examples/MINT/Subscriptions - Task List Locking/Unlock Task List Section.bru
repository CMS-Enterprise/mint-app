meta {
  name: Unlock Task List Section
  type: graphql
  seq: 5
}

post {
  url: {{url}}
  body: graphql
  auth: apikey
}

auth:apikey {
  key: Authorization
  value: Local {"EUAID":"{{EUAID}}","jobCodes":{{jobCodes}},"favorLocalAuth":true}
  placement: header
}

body:graphql {
  mutation unlockLockableSection ($modelPlanID: UUID!, $section: LockableSection!) {
      unlockLockableSection (modelPlanID: $modelPlanID, section: $section)
  }
}

body:graphql:vars {
  {
    "modelPlanID": "",
    "section": ""
  }
}
