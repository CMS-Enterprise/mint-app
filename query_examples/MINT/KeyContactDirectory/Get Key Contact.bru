meta {
  name: Get Key Contact
  type: graphql
  seq: 8
}

post {
  url: {{url}}
  body: graphql
  auth: inherit
}

body:graphql {
  query GetKeyContact($id:UUID!){
    keyContact(id: $id) {
      id
      name
      email
      subjectArea
      subjectCategoryID
    }
  }
}

body:graphql:vars {
  {
    "id": "{{keyContactID}}"
  }
}