meta {
  name: Bulk Update Custom Timeline Dates
  type: graphql
  seq: 6
}

post {
  url: {{url}}
  body: graphql
  auth: inherit
}

body:graphql {
  mutation BulkUpdateCustomTimelineDates($id: UUID!, $changes: PlanTimelineChanges!) {
    updatePlanTimeline(id: $id, changes: $changes) {
      id
      customTimelineDates {
        id
        modelPlanID
        title
        description
        dateType
        startDate
        endDate
        createdBy
        createdByUserAccount {
          id
          commonName
        }
        createdDts
        modifiedBy
        modifiedByUserAccount {
          id
          commonName
        }
        modifiedDts
      }
    }
  }
}

body:graphql:vars {
  {
    "id": "6bd328b2-aad9-4434-9bf7-3fe5401d5e54",
    "changes": {
      "customTimelineDateUpdates": [
        {
          "id": "dc09586b-1922-425c-bb96-f83cb6a0acba",
          "newStartDate": "2026-10-01T00:00:00Z",
          "newEndDate": null
        }
      ]
    }
  }
}
​
