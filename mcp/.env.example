# Application Configuration
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=5554
APP_RELOAD=True
APP_WORKERS=1
LOG_LEVEL=INFO

# MCP Transport Configuration
# Options: sse (default), streamable-http, http, stdio
# - sse: Server-Sent Events for HTTP streaming (recommended for most web UIs)
# - streamable-http: Alternative HTTP streaming protocol (for Open WebUI and similar)
# - http: Basic HTTP transport (message-based, non-streaming)
# - stdio: Standard input/output for CLI tools (like Claude Desktop)
MCP_TRANSPORT=streamable-http

# Authentication (shared with mint-app)
# For local development, use local auth (mimics frontend pattern)
LOCAL_AUTH_ENABLED=True
LOCAL_AUTH_EUA_ID=PSTM
LOCAL_AUTH_JOB_CODES=MINT_ASSESSMENT_NONPROD,MINT_USER_NONPROD

# For production/deployed environments, disable local auth and use JWT
# LOCAL_AUTH_ENABLED=False
# AUTH_SERVER_URL=https://test.idp.idm.cms.gov
# JWT_ISSUER=https://test.idp.idm.cms.gov
JWT_AUDIENCE=urn:gov:cms:mint:dev
JWT_ALGORITHM=RS256

# MINT Integration
MINT_GRAPHQL_URL=http://localhost:8085/api/graph/query

# Observability (optional - contact admins for keys)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_PRIVATE_KEY=
LANGFUSE_HOST=https://chat.cms.gov:3000
